# ─── Redis ───
REDIS_URL=redis://localhost:6379/0

# ─── TimescaleDB / PostgreSQL ───
POSTGRES_PASSWORD=qe_dev_password
DATABASE_URL=postgresql+asyncpg://qe_user:qe_dev_password@localhost:5432/quantum_edge

# ─── Alpaca (Paper Trading) ───
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# ─── News / Data APIs ───
FINNHUB_API_KEY=
NEWSAPI_KEY=
UNUSUAL_WHALES_API_KEY=

# ─── Agent Configuration ───
SIGNAL_COLLECTION_TIMEOUT_S=120
SMART_MONEY_TIMEOUT_S=60
PASS1_THRESHOLD=0.65
PASS2_THRESHOLD=0.75
MAX_DAILY_LOSS_PCT=6.0
MAX_POSITION_PCT=5.0
MAX_CORRELATED_EXPOSURE_PCT=15.0

# ─── Monitoring ───
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# ─── Logging ───
LOG_LEVEL=INFO
LOG_FORMAT=json

# ─── Environment ───
ENVIRONMENT=development
